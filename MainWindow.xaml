<Window x:Class="Worksheet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Worksheet"
        mc:Ignorable="d"
        Title="Worksheet" WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="8*"/>
        </Grid.ColumnDefinitions>

        <!--Left Sidebar-->
        <StackPanel Grid.Column="0" Background="LightGray">
            <TextBlock Text="Controls Panel" FontSize="20" FontWeight="Bold" Margin="10"/>
            <!-- Add more controls here as needed -->
        </StackPanel>

        <!--Main Content Area-->
        <Grid Grid.Column="1" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="9.5*"/>
            </Grid.RowDefinitions>

            <!--Navigation Panel-->
            <StackPanel Grid.Row="0" Background="LightBlue">
                <TextBlock Text="Navigation" FontSize="20" FontWeight="Bold" Margin="10"/>
                <!-- Add navigation items here as needed -->
            </StackPanel>

            <!--Worksheet Area-->
            <Grid Grid.Row="1" Background="WhiteSmoke">
                <TextBlock Text="Worksheet Area" FontSize="20" FontWeight="Bold" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <!-- Add worksheet content here as needed -->
            </Grid>
        </Grid>
    </Grid>
</Window>
