<UserControl x:Class="Worksheet.Views.Toolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Worksheet.Views"
             mc:Ignorable="d" >
    <Grid Background="LightBlue">
        <!-- Add navigation items here as needed -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
            <Button Content="Histogram Plot" Margin="5" Click="HistogramPlotButton_Click" />
            <Button Content="Load Config" Margin="5" Click="LoadConfigButton_Click" />
            <Button Content="Clear Memory" Margin="5" Click="ClearMemoryButton_Click" />
            <Button Content="Pseudocolor Plot" Margin="5" Click="PseudocolorPlotButton_Click" />
            <Button Content="Spectral Ribbon Plot" Margin="5" Click="SpectralRibbonPlotButton_Click" />
            <Button Content="Oscilloscope Plot" Margin="5" Click="OscilloscopePlotButton_Click" />
            <Separator Margin="8,4" Width="1" />
            <CheckBox x:Name="SnapToGridCheckBox"
                      Content="Snap to Grid"
                      VerticalAlignment="Center"
                      Margin="5"
                      Checked="SnapToGridCheckBox_Changed"
                      Unchecked="SnapToGridCheckBox_Changed" />
            <TextBox x:Name="SnapGridSizeTextBox"
                     Text="20"
                     Width="56"
                     Height="24"
                     Margin="5"
                     VerticalContentAlignment="Center"
                     LostFocus="SnapGridSizeTextBox_LostFocus"
                     KeyDown="SnapGridSizeTextBox_KeyDown" />
            <TextBlock Text="px"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0" />
        </StackPanel>
    </Grid>
</UserControl>
