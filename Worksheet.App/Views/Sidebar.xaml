<UserControl x:Class="Worksheet.Views.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Worksheet.Views"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PanelRootStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </UserControl.Resources>

    <Border Background="#F3F4F6"
            BorderBrush="#D1D5DB"
            BorderThickness="0,0,1,0"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelRootStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1F2937" Padding="16,12">
                        <TextBlock Text="Data Acquisition" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                    </Border>

                    <StackPanel Grid.Row="1" Margin="16,14,16,14">
                        <Button x:Name="StartStreamingButton"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Content="Start Streaming"
                                Background="#16A34A"
                                Margin="0,0,0,10"
                                Click="StartStreamingButton_Click" />

                        <Button x:Name="StopStreamingButton"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Content="Stop Streaming"
                                Background="#DC2626"
                                Margin="0,0,0,10"
                                Click="StopStreamingButton_Click" />

                        <TextBlock x:Name="StreamingStatusText"
                                   Text="Status: Stopped"
                                   Foreground="#991B1B"
                                   Margin="0,0,0,12"
                                   FontWeight="SemiBold" />

                        <TextBlock Text="Rolling Window"
                                   FontSize="12"
                                   Foreground="#374151"
                                   Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="RollingWindowTextBox"
                                     Grid.Column="0"
                                     Text="200000"
                                     Height="30"
                                     Padding="8,4"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1"
                                     KeyDown="RollingWindowTextBox_KeyDown" />

                            <Button x:Name="ApplyRollingWindowButton"
                                    Grid.Column="2"
                                    Content="Apply"
                                    Height="30"
                                    Padding="12,0"
                                    Click="ApplyRollingWindowButton_Click" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource PanelRootStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1F2937" Padding="16,12">
                        <TextBlock Text="Gate Stats" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                    </Border>

                    <Border Grid.Row="1" Background="White" Padding="12">
                        <DataGrid x:Name="GateStatsGrid"
                                  ItemsSource="{Binding GateStatsRows}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="None"
                                  RowBackground="#FFFFFF"
                                  AlternatingRowBackground="#F8FAFC"
                                  BorderThickness="1"
                                  BorderBrush="#D1D5DB"
                                  FontSize="12"
                                  MinHeight="160">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Gate" Binding="{Binding GateName}" Width="*" />
                                <DataGridTextColumn Header="Num" Binding="{Binding Num}" Width="*" />
                                <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="*" />
                                <DataGridTextColumn Header="Mean" Binding="{Binding Mean}" Width="*" />
                                <DataGridTextColumn Header="STD" Binding="{Binding STD}" Width="*" />
                                <DataGridTextColumn Header="CV" Binding="{Binding CV}" Width="*" />
                                <DataGridTextColumn Header="Var" Binding="{Binding Var}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PanelRootStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1F2937" Padding="16,12">
                        <TextBlock Text="Processing Status" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="16,14,16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MetricLabelStyle}" Text="Event Rate:" Margin="0,0,8,8" />
                            <TextBlock x:Name="EventRateValueText" Grid.Row="0" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Text="--" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MetricLabelStyle}" Text="Buffered Events:" Margin="0,0,8,8" />
                            <TextBlock x:Name="BufferedEventsValueText" Grid.Row="1" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Text="--" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MetricLabelStyle}" Text="Histogram Average Compute Time:" Margin="0,0,8,8" />
                            <TextBlock x:Name="HistogramComputeValueText" Grid.Row="2" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Text="--" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource MetricLabelStyle}" Text="Pseudocolor Average Compute Time:" Margin="0,0,8,8" />
                            <TextBlock x:Name="PseudocolorComputeValueText" Grid.Row="3" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Text="--" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource MetricLabelStyle}" Text="Spectral Ribbon Plot Average Compute Time:" Margin="0,0,8,8" />
                            <TextBlock x:Name="SpectralComputeValueText" Grid.Row="4" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Text="--" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource MetricLabelStyle}" Text="Histogram Average Render Time:" Margin="0,0,8,8" />
                            <TextBlock x:Name="HistogramRenderValueText" Grid.Row="5" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Text="--" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource MetricLabelStyle}" Text="Pseudocolor Average Render Time:" Margin="0,0,8,8" />
                            <TextBlock x:Name="PseudocolorRenderValueText" Grid.Row="6" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Text="--" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource MetricLabelStyle}" Text="Spectral Ribbon Average Render Time:" Margin="0,0,8,0" />
                            <TextBlock x:Name="SpectralRenderValueText" Grid.Row="7" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Text="--" Margin="0,0,0,0" />
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
