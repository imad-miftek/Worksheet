<Window x:Class="Worksheet.Views.PlotViews.Dialogs.PseudocolorPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pseudocolor Properties"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="X Feature" />
        <ComboBox x:Name="XFeatureComboBox" Grid.Row="0" Grid.Column="1" MinWidth="160" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,8,0" VerticalAlignment="Center" Text="Y Feature" />
        <ComboBox x:Name="YFeatureComboBox" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" MinWidth="160" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,8,0" VerticalAlignment="Center" Text="X Axis Scale" />
        <ComboBox x:Name="XAxisScaleComboBox" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" MinWidth="160" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,8,0" VerticalAlignment="Center" Text="Y Axis Scale" />
        <ComboBox x:Name="YAxisScaleComboBox" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" MinWidth="160" />

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="80" Margin="0,0,8,0" IsDefault="True" Content="OK" Click="Ok_Click" />
            <Button Width="80" IsCancel="True" Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>
